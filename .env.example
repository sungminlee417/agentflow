# Supabase ---------------------------------------------------------
# Web app (apps/web) — public values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Worker (apps/worker) — service role bypasses RLS
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# App secret -------------------------------------------------------
# 64 hex chars from `openssl rand -hex 32`. Used to encrypt user-
# provided API keys + OAuth tokens at rest. Server-only. Never expose
# to the browser. Don't lose this — losing it bricks all stored keys.
AGENTFLOW_SECRET_KEY=

# GitHub OAuth (Code Manager) --------------------------------------
# Create at https://github.com/settings/developers → New OAuth App
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google / YouTube OAuth (Social Media Manager — YouTube) ----------
# Create at https://console.cloud.google.com → APIs & Services →
# Credentials → OAuth client (Web application). Enable YouTube Data
# API v3 and YouTube Analytics API on the project.
#   Authorized redirect URI: http://localhost:3000/api/oauth/youtube/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# TikTok OAuth (Social Media Manager — TikTok) ---------------------
# Create at https://developers.tiktok.com → My apps. Enable "Login Kit"
# and "Display API". Add yourself as a Sandbox tester. Note: TikTok
# requires HTTPS callbacks — for local dev tunnel through ngrok and
# set the redirect URI to the public HTTPS URL.
#   Redirect URI (dev, via tunnel): https://<your-ngrok>.ngrok.io/api/oauth/tiktok/callback
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=

# Instagram OAuth (Social Media Manager — Instagram) ---------------
# Create at https://developers.facebook.com → My Apps → "Business" app
# type. Add the "Instagram" product, configure Instagram Login, and
# add the redirect URI. Add yourself as a Developer/Admin/Tester role.
# Requires Business or Creator Instagram account. HTTPS callback only
# — use a tunnel for local dev.
#   Redirect URI (dev, via tunnel): https://<your-ngrok>.ngrok.io/api/oauth/instagram/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
