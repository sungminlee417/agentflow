# Supabase ---------------------------------------------------------
# Web app (apps/web) — public values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Worker (apps/worker) — service role bypasses RLS
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# App secret -------------------------------------------------------
# 64 hex chars from `openssl rand -hex 32`. Used to encrypt user-
# provided API keys + OAuth tokens at rest. Server-only. Never expose
# to the browser. Don't lose this — losing it bricks all stored keys.
AGENTFLOW_SECRET_KEY=

# OAuth app credentials (optional — env-level fallback) -----------
# Each user can supply their own OAuth app credentials via the
# Integrations UI; the values below are used as a fallback when the
# user hasn't set their own. For single-user / single-tenant dev,
# filling these is the easy path. For multi-user / production, leave
# blank and have each user supply their own (necessary for TikTok and
# Meta where each user must be a Sandbox/test user on the OAuth app).

# GitHub OAuth — https://github.com/settings/developers
#   Authorization callback URL: http://localhost:3000/api/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google / YouTube OAuth — https://console.cloud.google.com
# Enable YouTube Data API v3 + Analytics API on the project.
#   Redirect URI: http://localhost:3000/api/oauth/youtube/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# TikTok OAuth — https://developers.tiktok.com (Login Kit + Display API)
# HTTPS callback required — use ngrok for local dev. Add yourself as
# a Sandbox tester on the app.
#   Redirect URI (dev, via tunnel): https://<your-ngrok>.ngrok.io/api/oauth/tiktok/callback
TIKTOK_OAUTH_CLIENT_KEY=
TIKTOK_OAUTH_CLIENT_SECRET=

# Instagram (Meta Graph API + Instagram Login) — https://developers.facebook.com
# Business app type, add Instagram product. HTTPS callback required.
# Add yourself as a Developer/Admin/Tester to skip App Review.
#   Redirect URI (dev, via tunnel): https://<your-ngrok>.ngrok.io/api/oauth/instagram/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
