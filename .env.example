# Supabase ---------------------------------------------------------
# Web app (apps/web) — public values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Worker (apps/worker) — service role bypasses RLS
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# App secret -------------------------------------------------------
# 64 hex chars from `openssl rand -hex 32`. Used to encrypt user-
# provided API keys + OAuth tokens at rest. Server-only. Never expose
# to the browser. Don't lose this — losing it bricks all stored keys.
AGENTFLOW_SECRET_KEY=

# GitHub OAuth (Connect button in Settings) ------------------------
# Create at https://github.com/settings/developers → New OAuth App
#   Homepage URL:         http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google / YouTube OAuth ------------------------------------------
# Not used yet — YouTube tool is the next integration.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
